{
  "name": "@mapbox-vision/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "lint": "biome lint src",
    "test": "node --require ts-node/register --require tsconfig-paths/register --test test/**/*.spec.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "seed:geo": "ts-node -r tsconfig-paths/register src/modules/geo/application/seed/run-geo-seed.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate src/database/migrations/Migration -d src/database/typeorm/data-source.ts",
    "migration:show": "typeorm-ts-node-commonjs migration:show -d src/database/typeorm/data-source.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/typeorm/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/typeorm/data-source.ts"
  },
  "dependencies": {
    "@mapbox-vision/shared": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.1",
    "@nestjs/typeorm": "11.0.1",
    "dotenv": "^17.4.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "0.3.28"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/node": "^22.10.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
